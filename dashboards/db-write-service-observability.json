{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source scraping /q/metrics of db-write-service",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Kafka consumer lag, DLQ / dropped-message events, and DB write throughput for the centralized DB Write Service. Backs recommendation #4 (operational dashboards around Kafka lag and DLQ events).",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["db-write-service", "kafka", "dlq", "observability"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Data source",
        "multi": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      },
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(kafka_dlq_events_total, channel)",
        "hide": 0,
        "includeAll": true,
        "label": "Channel",
        "multi": true,
        "name": "channel",
        "options": [],
        "query": { "query": "label_values(kafka_dlq_events_total, channel)", "refId": "channel" },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "DB Write Service — Kafka Lag & DLQ Observability",
  "uid": "db-write-service-obs",
  "version": 1,
  "weekStart": "",
  "panels": [
    {
      "type": "row",
      "title": "Kafka Consumer Lag",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "stat",
      "title": "Max consumer lag (all clients)",
      "description": "Highest client-side records-lag across all consumer clients. Exported by the Micrometer Kafka binder (quarkus.micrometer.binder.kafka.enabled=true).",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "red", "value": 5000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "max(kafka_consumer_fetch_manager_records_lag_max)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Consumer lag (max) by client",
      "description": "kafka_consumer_fetch_manager_records_lag_max per consumer client_id. Sustained growth means consumption is falling behind production.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 18, "x": 6, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never", "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 5000 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["max", "lastNotNull"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "max by (client_id) (kafka_consumer_fetch_manager_records_lag_max)",
          "legendFormat": "{{client_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Consumer lag by topic / partition",
      "description": "kafka_consumer_fetch_manager_records_lag broken down per topic/partition (when per-partition metrics are available).",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 7 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never", "lineWidth": 1 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["max", "lastNotNull"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (topic, partition) (kafka_consumer_fetch_manager_records_lag)",
          "legendFormat": "{{topic}}-{{partition}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Dead-Letter & Dropped Events",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "stat",
      "title": "Dead-lettered (last 24h)",
      "description": "Messages routed to a dead-letter topic — payload preserved for replay/triage.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 15 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 1 } ] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(increase(kafka_dlq_events_total[24h]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Dropped / lost (last 24h)",
      "description": "Messages acknowledged and discarded (failure-strategy: ignore) — payload lost. This is the higher-severity signal.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 15 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(increase(kafka_dropped_events_total[24h]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "DLQ event rate by channel",
      "description": "rate(kafka_dlq_events_total[5m]) by channel.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 15 },
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "custom": { "drawStyle": "line", "fillOpacity": 15, "showPoints": "never", "lineWidth": 2, "stacking": { "mode": "normal", "group": "A" } }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (channel) (rate(kafka_dlq_events_total{channel=~\"$channel\"}[5m]))",
          "legendFormat": "{{channel}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "DLQ + dropped event rate by reason",
      "description": "Terminal-failure rate grouped by reason (deserialization, db_permanent, db_transient_exhausted, missing_headers). A spike in db_transient_exhausted means the DB was down long enough to blow the retry budget.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 21 },
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "custom": { "drawStyle": "line", "fillOpacity": 15, "showPoints": "never", "lineWidth": 2, "stacking": { "mode": "normal", "group": "A" } }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (reason) (rate(kafka_dlq_events_total[5m]))",
          "legendFormat": "dlq:{{reason}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (reason) (rate(kafka_dropped_events_total[5m]))",
          "legendFormat": "dropped:{{reason}}",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Dropped (lost) event rate by channel",
      "description": "rate(kafka_dropped_events_total[5m]) by channel — messages lost on failure-strategy: ignore channels (UMS MySQL, dr-provisioning).",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 21 },
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "custom": { "drawStyle": "line", "fillOpacity": 15, "showPoints": "never", "lineWidth": 2, "stacking": { "mode": "normal", "group": "A" } },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (channel) (rate(kafka_dropped_events_total[5m]))",
          "legendFormat": "{{channel}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "DB Write Throughput & Failures",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 28 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "DB write throughput (TPS)",
      "description": "rate(db_updates_total[1m]) — successful single-row DB writes per second.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 29 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never", "lineWidth": 2 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(db_updates_total[1m]))",
          "legendFormat": "writes/s",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "DB write failure ratio",
      "description": "rate(db_updates_failures_total) / rate(db_updates_total) — fraction of DB writes failing.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 29 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never", "lineWidth": 2 },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 0.001 }, { "color": "red", "value": 0.01 } ] }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(db_updates_failures_total[5m])) / clamp_min(sum(rate(db_updates_total[5m])) + sum(rate(db_updates_failures_total[5m])), 1)",
          "legendFormat": "failure ratio",
          "refId": "A"
        }
      ]
    }
  ]
}
